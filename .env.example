# Required for Unpaywall API (free) — improves open-access PDF discovery
UNPAYWALL_EMAIL=research@scs-researchminds.local

# Required on networks with SSL inspection (same as .npmrc strict-ssl=false)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Optional: CORE API key for additional repository coverage
# CORE_API_KEY=

# API server port (default 3001)
# PORT=3001

# Kaggle API — required for Structured Data Extraction
# Create a token at https://www.kaggle.com/settings (Legacy API Credentials)
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
